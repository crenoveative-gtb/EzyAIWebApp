# Optional. Leave empty to use same-origin `/api` (via Vite proxy in dev)
VITE_API_URL=
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Optional: isolate auth session key for this app to avoid lock collisions with other local apps.
VITE_SUPABASE_AUTH_STORAGE_KEY=sb-YOUR_PROJECT_REF-auth-token-ezyaiagent
# Never use service role key in frontend
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx
